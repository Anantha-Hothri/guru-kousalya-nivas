# EmailJS Configuration
# Get these values from https://dashboard.emailjs.com/

# Your EmailJS Public Key (found in Account > API Keys)
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (found in Email Services)
REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (found in Email Templates)
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here

# Image Configuration
# Set to 'true' to use local images from /public/images
# Set to 'false' to use externally hosted images (recommended for Vercel)
REACT_APP_USE_LOCAL_IMAGES=false
