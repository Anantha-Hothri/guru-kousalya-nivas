# Image Configuration
# Set to 'true' to use local images from /public/images
# Set to 'false' to use externally hosted images (recommended for Vercel)
REACT_APP_USE_LOCAL_IMAGES=false

# Contact Form Configuration
# The contact form uses FormSubmit.co (no API keys required)
# Email destination is configured in src/data/contactConfig.js
# On first submission, FormSubmit will send a verification email to activate the form
